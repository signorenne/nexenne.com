{
  "name": "nexenne",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && node scripts/postbuild.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.{ts,js,svelte,css,html}\" \"*.{ts,js,mjs,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,svelte,css,html}\" \"*.{ts,js,mjs,json,md}\"",
    "lint": "eslint . --ext .ts,.js,.svelte",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-wasm": "^2.6.2",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "satori": "^0.26.0",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "svelte-eslint-parser": "^1.6.1",
    "tslib": "^2.7.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.0",
    "vitest": "^3"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "uniorg-parse": "^3.2.1",
    "uniorg-rehype": "^2.2.0",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "cookie": "^0.7.0"
  },
  "packageManager": "yarn@4.15.0"
}
